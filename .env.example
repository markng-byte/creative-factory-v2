# Root environment (documentation only — copy per app as needed)
# See apps/web/.env.example and apps/api/.env.example

# Web
NEXT_PUBLIC_APP_NAME=Creative Factory
NEXT_PUBLIC_API_URL=http://localhost:8000

# API
APP_NAME=Creative Factory API
APP_VERSION=0.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Future infrastructure (not wired in scaffold)
DATABASE_URL=postgresql://creative_factory:creative_factory@localhost:5432/creative_factory
REDIS_URL=redis://localhost:6379/0
